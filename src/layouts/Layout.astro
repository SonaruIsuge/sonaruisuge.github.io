---
interface Props {
	title: string;
}

const { title } = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Full Stack Developer Portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-white dark:bg-gray-950 transition-colors duration-300">
		<slot />
		<script>
			declare global {
				interface Window {
					toggleTheme: () => void;
					toggleLang: () => void;
					updatePageContent: () => void;
				}
			}

			// Initialize theme from localStorage if possible, to stay in sync
			const savedTheme = localStorage.getItem('theme');
			if (savedTheme) {
				document.documentElement.classList.toggle('dark', savedTheme === 'dark');
			}

			let currentLang = localStorage.getItem('lang') || 'jp';
			if (!['en', 'jp'].includes(currentLang)) {
				currentLang = 'jp';
			}
			document.documentElement.setAttribute('data-lang', currentLang);
			document.documentElement.setAttribute('lang', currentLang === 'jp' ? 'ja' : 'en');

			window.updatePageContent = function() {
				const lang = document.documentElement.getAttribute('data-lang') || 'jp';
				
				const langBtn = document.getElementById('lang-btn');
				if (langBtn) {
					langBtn.textContent = lang === 'jp' ? 'JP' : 'EN';
				}

				document.querySelectorAll('[data-en]').forEach(el => {
					const en = el.getAttribute('data-en');
					const jp = el.getAttribute('data-jp');
					if (en && jp) {
						// If the element already contains styled spans, recreate its HTML safely
						if (el.innerHTML.includes('<span')) {
							if (lang === 'jp') {
								// For the JP language slot, keep the current placeholder text until the data is replaced
								el.innerHTML = jp.replace('Technologist in Information Systems', '<span class="font-semibold text-gray-900 dark:text-white">Tecnólogo en Sistemas de información</span>')
									.replace('Full Stack Developer', '<span class="font-semibold text-gray-900 dark:text-white">Desarrollador Full Stack</span>');
							} else {
								// English slot
								el.innerHTML = en.replace('Technologist in Information Systems', '<span class="font-semibold text-gray-900 dark:text-white">Technologist in Information Systems</span>')
									.replace('Full Stack Developer', '<span class="font-semibold text-gray-900 dark:text-white">Full Stack Developer</span>');
							}
						} else {
							el.textContent = lang === 'jp' ? jp : en;
						}
					}
				});

				document.querySelectorAll('[data-en-placeholder]').forEach(el => {
					const en = el.getAttribute('data-en-placeholder');
					const jp = el.getAttribute('data-jp-placeholder');
					if (en && jp) {
						(el as HTMLInputElement | HTMLTextAreaElement).placeholder = lang === 'jp' ? jp : en;
					}
				});

				document.querySelectorAll('[data-en-label]').forEach(el => {
					const en = el.getAttribute('data-en-label');
					const jp = el.getAttribute('data-jp-label');
					if (en && jp) {
						(el as HTMLLabelElement).textContent = lang === 'jp' ? jp : en;
					}
				});
			};

			window.toggleTheme = () => {
				const isDark = document.documentElement.classList.toggle('dark');
				const theme = isDark ? 'dark' : 'light';
				localStorage.setItem('theme', theme);
				// Also set a cookie so the server knows the theme on next request
				document.cookie = `theme=${theme}; path=/; max-age=31536000`;
			};

			window.toggleLang = () => {
				// Create overlay
				const overlay = document.createElement('div');
				overlay.className = 'lang-change-overlay';
				
				const modal = document.createElement('div');
				modal.className = 'lang-change-modal';
				
				const currentLangAttr = document.documentElement.getAttribute('data-lang') || 'en';
				const isJapanese = currentLangAttr === 'jp';
				const text = isJapanese ? 'Changing language...' : '言語を変更中...';
				
				modal.innerHTML = `<h2>${text}</h2>`;
				overlay.appendChild(modal);
				document.body.appendChild(overlay);
				
				// Change language after 1 second
				setTimeout(() => {
					currentLang = currentLang === 'en' ? 'jp' : 'en';
					document.documentElement.setAttribute('data-lang', currentLang);
					document.documentElement.setAttribute('lang', currentLang === 'jp' ? 'ja' : 'en');
					localStorage.setItem('lang', currentLang);
					window.updatePageContent();
					
					// Hide overlay after 500ms
					overlay.classList.add('hidden');
					setTimeout(() => {
						overlay.remove();
					}, 300);
				}, 1000);
			};

			document.addEventListener('DOMContentLoaded', () => {
				window.updatePageContent();
			});
		</script>
	</body>
</html>
