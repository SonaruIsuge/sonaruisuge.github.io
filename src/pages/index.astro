---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import heroPhoto from "../assets/photo.jpeg";
import cvFile from "../assets/CV/CV_Javier_Castillo.pdf";

import translation from "../data/translation.json";
import aboutData from "../data/about.json";
---

<Layout title={`Home | Javier Castillo`}>
	<Header />

	<main class="min-h-screen px-4 sm:px-6 md:px-6">
		<section
			class="max-w-3xl mx-auto min-h-[calc(100vh-5rem)] flex flex-col justify-center pt-32 sm:pt-48 pb-16 sm:pb-24 fade-in"
		>
			<div class="flex flex-col items-center gap-6 sm:gap-8 text-center">
				<div
					class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4"
				>
					<div
						class="w-24 h-24 sm:w-28 sm:h-28 md:w-32 md:h-32 rounded-full bg-gray-100 dark:bg-gray-800 border-2 border-gray-300 dark:border-gray-600 flex items-center justify-center overflow-hidden animated-border always-visible flex-shrink-0 shadow-lg dark:shadow-white/20"
					>
						<img
							src={heroPhoto.src}
							alt="Javier Castillo"
							class="w-full h-full object-cover"
							onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
						/>
						<span
							class="text-2xl sm:text-3xl md:text-4xl text-gray-500 dark:text-gray-400 hidden"
							>?</span
						>
					</div>
					<div
						class="animated-border always-visible px-3 sm:px-4 py-2 rounded-full border border-gray-300 dark:border-gray-600 h-fit"
					>
						<p
							class="text-xs sm:text-sm font-medium text-gray-900 dark:text-white whitespace-nowrap"
							data-en={translation.about.availability.en}
							data-es={translation.about.availability.es}
						>
							{translation.about.availability.en}
						</p>
					</div>
				</div>
				<div>
					<p
						class="text-xs sm:text-sm font-medium text-gray-600 dark:text-gray-400 mb-2"
						data-en={translation.about.greeting.en}
						data-es={translation.about.greeting.es}
					>
						{translation.about.greeting.en}
					</p>
					<h1
						class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4 sm:mb-6 px-2 sm:px-0"
						data-en={aboutData.about.name.en}
						data-es={aboutData.about.name.es}
					>
						{aboutData.about.name.en}
					</h1>
					<p
						class="text-sm sm:text-base text-gray-600 dark:text-gray-400 max-w-lg mx-auto mb-4 sm:mb-6 px-2 sm:px-0"
						data-en={aboutData.about.description.en}
						data-es={aboutData.about.description.es}
					>
						{aboutData.about.description.en}
					</p>
					<div
						class="flex flex-wrap gap-2 sm:gap-3 justify-center px-2 sm:px-0"
					>
						<a
							href="/projects"
							class="cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-medium rounded-full hover:animated-bg transition-all"
							data-en={translation.about.viewProjects.en}
							data-es={translation.about.viewProjects.es}
						>
							{translation.about.viewProjects.en}
						</a>
						<a
							href="/contact"
							class="animated-border cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white font-medium rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
							data-en={translation.about.getInTouch.en}
							data-es={translation.about.getInTouch.es}
						>
							{translation.about.getInTouch.en}
						</a>
					</div>
					<div class="mt-8 sm:mt-10 flex justify-center px-2 sm:px-0">
						<article
							class="cv-download-card group"
							aria-label="Download CV card"
						>
							<div class="cv-download-card-inner">
								<div class="text-gray-50 text-left">
									<span class="cv-initials">Jr</span>
									<p
										class="cv-role"
										data-en={aboutData.about.roleTitle.en}
										data-es={aboutData.about.roleTitle.es}
									>
										{aboutData.about.roleTitle.en}
									</p>
								</div>
								<a
									href={cvFile}
									download="CV_Javier_Castillo.pdf"
									class="cv-download-button"
									data-en={translation.about.downloadCv.en}
									data-es={translation.about.downloadCv.es}
								>
									<span>{translation.about.downloadCv.en}</span>
									<svg
										class="w-5 h-5 fill-current"
										viewBox="0 0 100 100"
										xmlns="http://www.w3.org/2000/svg"
										aria-hidden="true"
									>
										<path
											d="M22.1,77.9a4,4,0,0,1,4-4H73.9a4,4,0,0,1,0,8H26.1A4,4,0,0,1,22.1,77.9ZM35.2,47.2a4,4,0,0,1,5.7,0L46,52.3V22.1a4,4,0,1,1,8,0V52.3l5.1-5.1a4,4,0,0,1,5.7,0,4,4,0,0,1,0,5.6l-12,12a3.9,3.9,0,0,1-5.6,0l-12-12A4,4,0,0,1,35.2,47.2Z"
											fill-rule="evenodd"></path>
									</svg>
								</a>
							</div>

							<svg
								class="cv-avatar cv-avatar-main"
								xmlns="http://www.w3.org/2000/svg"
								viewBox="0 0 64 64"
								aria-hidden="true"
								><path
									d="M50.4 51C40.5 49.1 40 46 40 44v-1.2a18.9 18.9 0 0 0 5.7-8.8h.1c3 0 3.8-6.3 3.8-7.3s.1-4.7-3-4.7C53 4 30 0 22.3 6c-5.4 0-5.9 8-3.9 16-3.1 0-3 3.8-3 4.7s.7 7.3 3.8 7.3c1 3.6 2.3 6.9 4.7 9v1.2c0 2 .5 5-9.5 6.8S2 62 2 62h60a14.6 14.6 0 0 0-11.6-11z"
								></path></svg
							>
							<svg
								class="cv-avatar cv-avatar-accent"
								xmlns="http://www.w3.org/2000/svg"
								viewBox="0 0 64 64"
								aria-hidden="true"
								><path
									d="M50.4 51C40.5 49.1 40 46 40 44v-1.2a18.9 18.9 0 0 0 5.7-8.8h.1c3 0 3.8-6.3 3.8-7.3s.1-4.7-3-4.7C53 4 30 0 22.3 6c-5.4 0-5.9 8-3.9 16-3.1 0-3 3.8-3 4.7s.7 7.3 3.8 7.3c1 3.6 2.3 6.9 4.7 9v1.2c0 2 .5 5-9.5 6.8S2 62 2 62h60a14.6 14.6 0 0 0-11.6-11z"
								></path></svg
							>
						</article>
					</div>
				</div>
			</div>
		</section>

		<section
			class="max-w-3xl mx-auto py-12 sm:py-16 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0"
		>
			<h2
				class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-6 sm:mb-8"
				data-en={translation.about.aboutMe.en}
				data-es={translation.about.aboutMe.es}
			>
				{translation.about.aboutMe.en}
			</h2>
			<div
				class="space-y-3 sm:space-y-4 text-base sm:text-lg leading-relaxed text-gray-600 dark:text-gray-400"
				data-en={aboutData.about.description.en}
				data-es={aboutData.about.description.es}
			>
				{aboutData.about.description.en}
			</div>
		</section>

		<section
			class="max-w-3xl mx-auto py-12 sm:py-16 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0"
		>
			<h2
				class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-6 sm:mb-8"
				data-en={translation.about.tech.en}
				data-es={translation.about.tech.es}
			>
				{translation.about.tech.en}
			</h2>

			<div class="tech-ticker-container">
				<div class="tech-ticker-content">
					<!-- First set -->
					{
						aboutData.techStack.map((tech) => (
							<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
								<p class="text-sm font-medium text-gray-900 dark:text-white">
									{tech}
								</p>
							</div>
						))
					}

					<!-- Second set for seamless looping -->
					{
						aboutData.techStack.map((tech) => (
							<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
								<p class="text-sm font-medium text-gray-900 dark:text-white">
									{tech}
								</p>
							</div>
						))
					}
				</div>
			</div>
		</section>
	</main>

	<Footer />

	<script>
		document.addEventListener("DOMContentLoaded", () => {
			const observerOptions = {
				root: null,
				rootMargin: "0px",
				threshold: 0.1,
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add("visible");
					}
				});
			}, observerOptions);

			document.querySelectorAll(".fade-in").forEach((el) => {
				observer.observe(el);
			});

			window.addEventListener("scroll", () => {
				const scrolled = window.pageYOffset;
				document
					.querySelectorAll(".parallax-section")
					.forEach((section) => {
						const speed = 0.1;
						(section as HTMLElement).style.transform =
							`translateY(${scrolled * speed}px)`;
					});
			});
		});
	</script>
</Layout>
